<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
  <title>__LESSON_TITLE__</title>
  <style>
    @font-face { font-family:"Display"; src:url("fonts/Poppins-800.woff2") format("woff2"); font-weight:800; font-display:swap; }
    @font-face { font-family:"Display"; src:url("fonts/Poppins-600.woff2") format("woff2"); font-weight:600; font-display:swap; }
    @font-face { font-family:"Body"; src:url("fonts/Inter-400.woff2") format("woff2"); font-weight:400; font-display:swap; }
    @font-face { font-family:"Body"; src:url("fonts/Inter-700.woff2") format("woff2"); font-weight:700; font-display:swap; }

    :root {
      --accent: __ACCENT__;            /* brand color */
      --ink: #18241d;
      --muted: #5d6b63;
      --bg: #f7f7ea;                   /* warm cream stage */
      --paper: #ffffff;
      --line: #e7e8d8;
      --gold: #ffd23f; --coral: #ff7a4d; --grape: #7c6cf0; --sky: #4ea8ff;
      --r: 22px;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; height: 100%; }
    body {
      font-family: "Body", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      color: var(--ink); background: var(--bg); font-size: 19px; line-height: 1.5;
      height: 100vh; overflow: hidden; display: flex; flex-direction: column;
    }
    h1,h2,h3,h4,.display { font-family: "Display", system-ui, sans-serif; font-weight: 800; }

    /* ---- region 1: the lesson — full width, fills all height above the nav ---- */
    .stage { position: relative; flex: 1 1 auto; min-height: 0; overflow: hidden; background: var(--bg); }

    /* decorative shape layer — the "personality" behind every slide */
    .deco { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
    .deco span { position: absolute; display: block; }
    .deco .blob { width: 360px; height: 360px; right: -90px; bottom: -120px; border-radius: 46% 54% 60% 40%/52% 44% 56% 48%;
      background: var(--accent); opacity: .16; }
    .deco .ring { width: 190px; height: 190px; left: -60px; top: -60px; border-radius: 50%;
      border: 26px solid var(--gold); opacity: .35; }
    .deco .pill2 { width: 230px; height: 96px; right: 12%; top: -42px; border-radius: 99px; background: var(--coral);
      opacity: .2; transform: rotate(-12deg); }
    .deco .tri { width: 0; height: 0; left: 7%; bottom: 8%; border-left: 34px solid transparent; border-right: 34px solid transparent;
      border-bottom: 58px solid var(--grape); opacity: .22; transform: rotate(14deg); }
    .deco .dots { width: 150px; height: 110px; right: 5%; bottom: 16%; opacity: .5;
      background-image: radial-gradient(var(--accent) 2.4px, transparent 2.6px); background-size: 22px 22px; }
    /* per-slide color variety: recolor the cast each slide, keep positions (brand cohesion) */
    .stage.v1 .deco .blob { background: var(--grape); } .stage.v1 .deco .ring { border-color: var(--coral); } .stage.v1 .deco .pill2 { background: var(--gold); }
    .stage.v2 .deco .blob { background: var(--coral); } .stage.v2 .deco .ring { border-color: var(--accent); } .stage.v2 .deco .pill2 { background: var(--grape); }
    .stage.v3 .deco .blob { background: var(--gold); } .stage.v3 .deco .ring { border-color: var(--grape); } .stage.v3 .deco .pill2 { background: var(--accent); }

    .slide { position: relative; z-index: 1; width: 100%; height: 100%; display: flex; flex-direction: column; animation: fade .4s ease; }
    @keyframes fade { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
    @keyframes pop { from { opacity: 0; transform: scale(.96); } to { opacity: 1; transform: none; } }

    .slide-head { flex: 0 0 auto; padding: 34px 56px 0; }
    .eyebrow { display: inline-block; background: var(--accent); color: #fff; font-family: "Display"; font-weight: 600;
      font-size: 13px; letter-spacing: 1.3px; text-transform: uppercase; padding: 6px 14px; border-radius: 99px; margin-bottom: 12px; }
    .slide-title { margin: 0; font-size: 40px; line-height: 1.08; letter-spacing: -.5px; }
    .slide-title .u { color: var(--accent); }
    .slide-body { flex: 1 1 auto; padding: 22px 56px 30px; overflow: hidden; min-height: 0; }
    .slide-body.center { display: flex; flex-direction: column; justify-content: center; }
    .wrap { width: 100%; max-width: 1000px; margin: 0 auto; }
    .slide-body > * + *, .wrap > * + * { margin-top: 18px; }

    /* ---- split layout: text beside image, fits the frame (no scroll) ---- */
    .slide-body.split { display: grid; grid-template-columns: 1.05fr .95fr; gap: 44px;
      align-items: center; max-width: 1180px; margin: 0 auto; }
    .slide-body.split.img-left .split-text { order: 2; } .slide-body.split.img-left .split-media { order: 1; }
    .slide-body.split .split-text { min-width: 0; } .slide-body.split .split-text > * + * { margin-top: 18px; }
    .slide-body.split .split-media { display: flex; flex-direction: column; justify-content: center; gap: 16px; min-width: 0; }
    .slide-body.split .split-media .c-img { max-width: 100%; margin: 0 auto; }
    .slide-body.split .split-media .c-img img { max-height: calc(100vh - 230px); width: 100%; object-fit: cover; }

    /* ---- cover layout ---- */
    .cover { display: grid; grid-template-columns: 1.1fr .9fr; gap: 30px; align-items: center; height: 100%; padding: 0 56px; }
    .cover.solo { grid-template-columns: 1fr; text-align: left; }
    .cover-title { font-size: 60px; line-height: 1.02; letter-spacing: -1.5px; margin: 14px 0 18px; }
    .cover-sub { font-size: 21px; color: var(--muted); max-width: 30ch; }
    .cover-art { position: relative; aspect-ratio: 4/4.4; }
    .cover-art::before { content: ""; position: absolute; inset: 8% -6% -8% 8%; border-radius: 30px; background: var(--accent); opacity: .9; }
    .cover-art img { position: relative; width: 100%; height: 100%; object-fit: cover; border-radius: 26px; box-shadow: 0 18px 50px rgba(20,40,30,.18); }

    /* ---- section layout ---- */
    .section { display: flex; flex-direction: column; justify-content: center; height: 100%; padding: 0 56px; }
    .section .num { font-family: "Display"; font-weight: 800; font-size: 130px; line-height: .9; color: var(--accent); opacity: .9; }
    .section .section-title { font-size: 50px; line-height: 1.05; letter-spacing: -1px; margin-top: 6px; max-width: 18ch; }

    /* ---- components ---- */
    .c-h { font-family:"Display"; font-size: 30px; font-weight: 800; margin: 0; letter-spacing: -.3px; }
    .c-sub { font-family:"Display"; font-size: 22px; font-weight: 800; margin: 0; }
    .c-p { font-size: 20px; line-height: 1.62; margin: 0; }
    .c-p em { color: var(--muted); font-style: italic; }
    .c-statement { background: var(--accent); color: #fff; font-family:"Display"; font-weight: 800; font-size: 30px; line-height: 1.3;
      padding: 34px 38px; border-radius: var(--r); position: relative; overflow: hidden; animation: pop .4s ease; }
    .c-statement::after { content: ""; position: absolute; right: -40px; bottom: -40px; width: 150px; height: 150px; border-radius: 50%; background: rgba(255,255,255,.14); }
    .c-note { background: color-mix(in srgb, var(--accent) 12%, #fff); border-left: 6px solid var(--accent);
      padding: 18px 20px 18px 18px; border-radius: 14px; font-size: 19px; line-height: 1.55; display: flex; gap: 12px; }
    .c-note::before { content: "💡"; font-size: 22px; line-height: 1.4; }
    .c-quote { background: var(--paper); border-radius: var(--r); padding: 30px 34px; font-size: 24px; font-weight: 600; font-family:"Display";
      line-height: 1.4; position: relative; box-shadow: 0 10px 34px rgba(20,40,30,.07); }
    .c-quote::before { content: "“"; font-family:"Display"; font-size: 90px; color: var(--accent); position: absolute; left: 18px; top: -6px; line-height: 1; opacity: .9; }
    .c-quote .qt { display: block; padding-left: 46px; } .c-quote .by { display: block; margin-top: 12px; font-size: 16px; color: var(--muted); font-weight: 700; font-family:"Body"; }

    ul.c-list, ol.c-list { margin: 0; padding-left: 6px; font-size: 20px; line-height: 1.5; list-style: none; }
    ul.c-list li, ol.c-list li { position: relative; padding: 4px 0 4px 36px; }
    ul.c-list li::before { content: ""; position: absolute; left: 4px; top: 13px; width: 12px; height: 12px; border-radius: 4px; background: var(--accent); }
    ol.c-list { counter-reset: li; } ol.c-list li::before { counter-increment: li; content: counter(li); position: absolute; left: 0; top: 3px;
      width: 26px; height: 26px; background: var(--accent); color: #fff; border-radius: 8px; display: grid; place-items: center; font-size: 14px; font-weight: 800; font-family:"Display"; }
    ul.c-check li { padding-left: 40px; margin-bottom: 4px; }
    ul.c-check li::before { content: "✓"; top: 5px; width: 24px; height: 24px; border-radius: 8px; color: #fff; font-size: 14px; font-weight: 900; display: grid; place-items: center; }

    .c-img { position: relative; width: 100%; max-width: 720px; }
    .c-img::before { content: ""; position: absolute; inset: 14px -14px -14px 14px; background: var(--accent); opacity: .85; border-radius: 20px; }
    .c-img img { position: relative; width: 100%; border-radius: 18px; display: block; box-shadow: 0 14px 40px rgba(20,40,30,.15); }
    .c-img figcaption { position: relative; color: var(--muted); font-size: 16px; margin-top: 16px; }
    .c-grid { display: grid; gap: 18px; } .c-grid.cols-2 { grid-template-columns: repeat(2,1fr); } .c-grid.cols-3 { grid-template-columns: repeat(3,1fr); }
    .c-grid img { width: 100%; border-radius: 16px; box-shadow: 0 10px 28px rgba(20,40,30,.12); aspect-ratio: 4/3; object-fit: cover; }
    .c-media { width: 100%; max-width: 720px; } .c-media audio, .c-media video { width: 100%; border-radius: 14px; }
    .c-code { background: #14241c; color: #d7f5e6; padding: 20px; border-radius: 16px; overflow-x: auto;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; font-size: 16px; line-height: 1.55; }
    .c-btn { display: inline-flex; align-items: center; gap: 10px; background: var(--accent); color: #fff; text-decoration: none;
      font-family:"Display"; font-weight: 600; font-size: 18px; padding: 13px 16px 13px 24px; border-radius: 99px; }
    .c-btn::after { content: "→"; display: grid; place-items: center; width: 30px; height: 30px; background: rgba(255,255,255,.22); border-radius: 50%; }

    .c-acc details { background: var(--paper); border-radius: 14px; padding: 0 20px; box-shadow: 0 6px 20px rgba(20,40,30,.06); }
    .c-acc details + details { margin-top: 12px; }
    .c-acc summary { cursor: pointer; font-family:"Display"; font-weight: 800; font-size: 20px; padding: 18px 0; list-style: none; }
    .c-acc summary::-webkit-details-marker { display: none; }
    .c-acc summary::after { content: "+"; float: right; color: var(--accent); font-size: 26px; line-height: 1; }
    .c-acc details[open] summary::after { content: "–"; }
    .c-acc .acc-body { padding: 0 0 18px; font-size: 19px; line-height: 1.6; color: var(--muted); }

    .c-tabs .tab-strip { display: flex; gap: 8px; flex-wrap: wrap; }
    .c-tabs .tab-strip button { border: 0; background: var(--paper); font: inherit; font-family:"Display"; font-weight: 600; font-size: 17px;
      color: var(--muted); padding: 11px 18px; cursor: pointer; border-radius: 99px; box-shadow: 0 4px 14px rgba(20,40,30,.06); }
    .c-tabs .tab-strip button.active { color: #fff; background: var(--accent); }
    .c-tabs .tab-body { background: var(--paper); border-radius: 16px; padding: 22px 24px; margin-top: 14px; font-size: 19px; line-height: 1.6; box-shadow: 0 8px 24px rgba(20,40,30,.06); }

    .c-flash { perspective: 1200px; max-width: 560px; margin: 0 auto; }
    .c-flash .card { position: relative; min-height: 200px; cursor: pointer; transform-style: preserve-3d; transition: transform .55s; }
    .c-flash .card.flipped { transform: rotateY(180deg); }
    .c-flash .face { position: absolute; inset: 0; backface-visibility: hidden; border-radius: 20px; display: grid; place-items: center;
      padding: 26px; text-align: center; font-family:"Display"; font-size: 22px; font-weight: 600; }
    .c-flash .front { background: var(--paper); border: 3px solid var(--accent); box-shadow: 0 12px 34px rgba(20,40,30,.1); }
    .c-flash .back { transform: rotateY(180deg); background: var(--accent); color: #fff; }
    .c-flash .hint { text-align: center; color: var(--muted); font-size: 15px; margin-top: 10px; }
    .c-flash .nav { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 12px; }
    .c-flash .nav button { border: 0; background: var(--accent); color: #fff; width: 38px; height: 38px; border-radius: 99px; cursor: pointer; font-weight: 900; font-size: 18px; }

    .c-sort .pool { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
    .c-sort .chip { background: var(--paper); border: 2px solid var(--accent); color: var(--ink); border-radius: 99px; padding: 11px 18px;
      cursor: grab; font-weight: 700; font-size: 18px; box-shadow: 0 4px 14px rgba(20,40,30,.07); }
    .c-sort .piles { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); }
    .c-sort .pile { background: color-mix(in srgb, var(--accent) 7%, #fff); border: 2px dashed color-mix(in srgb, var(--accent) 40%, #fff);
      border-radius: 16px; padding: 14px; min-height: 110px; }
    .c-sort .pile h4 { margin: 0 0 10px; font-family:"Display"; font-size: 16px; }
    .c-sort .pile.over { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 14%, #fff); }
    .c-sort .chip.correct { border-color: #16a34a; } .c-sort .chip.wrong { border-color: #dc2626; }

    .c-timeline { position: relative; padding-left: 26px; }
    .c-timeline::before { content: ""; position: absolute; left: 7px; top: 6px; bottom: 6px; width: 3px; background: color-mix(in srgb, var(--accent) 35%, #fff); }
    .c-timeline .ev { position: relative; padding-bottom: 20px; }
    .c-timeline .ev::before { content: ""; position: absolute; left: -26px; top: 4px; width: 16px; height: 16px; border-radius: 99px; background: var(--accent); box-shadow: 0 0 0 4px var(--bg); }
    .c-timeline .date { color: var(--accent); font-family:"Display"; font-weight: 800; font-size: 15px; }

    .c-quiz { background: var(--paper); border-radius: var(--r); padding: 28px 30px; box-shadow: 0 12px 34px rgba(20,40,30,.08); }
    .c-quiz .q { font-family:"Display"; font-size: 23px; font-weight: 800; margin-bottom: 16px; }
    .c-quiz .opt { display: block; border: 2px solid var(--line); border-radius: 14px; padding: 15px 18px; margin-bottom: 11px; cursor: pointer;
      font-size: 19px; transition: border-color .15s, background .15s, transform .1s; }
    .c-quiz .opt:hover { border-color: var(--accent); transform: translateX(3px); }
    .c-quiz .opt.sel { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 9%, #fff); }
    .c-quiz .opt.correct { border-color: #16a34a; background: #f0fdf4; } .c-quiz .opt.wrong { border-color: #dc2626; background: #fef2f2; }
    .c-quiz input[type=text] { font: inherit; font-size: 19px; padding: 14px 16px; border: 2px solid var(--line); border-radius: 12px; width: 100%; }
    .c-quiz .check { margin-top: 14px; background: var(--accent); color: #fff; border: 0; font-family:"Display"; font-weight: 600; font-size: 18px; padding: 13px 28px; border-radius: 99px; cursor: pointer; }
    .c-quiz .fb { margin-top: 14px; padding: 14px 16px; border-radius: 12px; font-size: 17px; display: none; }
    .c-quiz .fb.show { display: block; } .c-quiz .fb.ok { background: #f0fdf4; color: #166534; } .c-quiz .fb.no { background: #fef2f2; color: #991b1b; }

    /* ---- region 2: nav ---- */
    .navbar { flex: 0 0 auto; background: var(--paper); border-top: 1px solid var(--line); }
    .progress-strip { display: block; height: 5px; width: 0; background: var(--accent); transition: width .4s ease; }
    .nav-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 26px; }
    .navbar button { border: 0; cursor: pointer; font-family:"Display"; font-size: 18px; font-weight: 600; color: #fff; background: var(--accent);
      padding: 13px 28px; border-radius: 99px; min-width: 132px; transition: filter .15s, opacity .15s; }
    .navbar button:hover { filter: brightness(1.07); }
    .navbar button:disabled { opacity: .32; cursor: default; }
    .navbar button.ghost { background: transparent; color: var(--accent); box-shadow: inset 0 0 0 2px var(--accent); }
    .counter { font-family:"Display"; font-weight: 800; font-size: 18px; color: var(--muted); font-variant-numeric: tabular-nums; }

    @media (max-width: 760px) {
      body { font-size: 18px; }
      .slide-head { padding: 22px 24px 0; } .slide-body { padding: 16px 24px 24px; }
      .slide-title { font-size: 30px; } .cover, .section { padding: 0 24px; } .cover { grid-template-columns: 1fr; }
      .slide-body.split { grid-template-columns: 1fr; gap: 18px; overflow-y: auto; }
      .slide-body.split.img-left .split-text, .slide-body.split.img-left .split-media { order: 0; }
      .slide-body.split .split-media .c-img img { max-height: 38vh; }
      .cover-title { font-size: 40px; } .cover-art { display: none; } .section .num { font-size: 92px; } .section .section-title { font-size: 34px; }
      .navbar button { min-width: 104px; padding: 12px 18px; font-size: 17px; }
    }
  </style>
</head>
<body>
  <!-- region 1: the lesson — full width, height = 100vh minus the nav below -->
  <div class="stage" id="stage">
    <div class="deco"><span class="blob"></span><span class="ring"></span><span class="pill2"></span><span class="tri"></span><span class="dots"></span></div>
    <div class="slide" id="slide" role="group" aria-roledescription="slide"></div>
  </div>
  <!-- region 2: nav — Back / Next + slide counter, identical on every slide -->
  <nav class="navbar">
    <i id="progressBar" class="progress-strip"></i>
    <div class="nav-row">
      <button id="prevBtn" class="ghost" type="button">‹ Back</button>
      <span class="counter" id="counter">1 / 1</span>
      <button id="nextBtn" type="button">Next ›</button>
    </div>
  </nav>

  <script id="__LESSON__" type="application/json">__LESSON_JSON__</script>
  <script src="icons.js"></script>
  <script src="player.js"></script>
</body>
</html>
